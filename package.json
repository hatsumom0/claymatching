{
  "name": "claymatching",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:sui": "vite build --config vite.claymatching-sui.config.mjs",
    "build:static": "node scripts/prepare-static.mjs",
    "verify:assets": "node scripts/verify-assets.mjs",
    "build": "npm run build:sui && npm run verify:assets && npm run build:static",
    "apple:secret": "node scripts/generate-apple-client-secret.mjs",
    "test:claymatching": "node --test tests/claymatching-worker.test.mjs",
    "test:relay": "node --test tests/noctweave-relay.test.mjs tests/noctweave-upstream-compat.test.mjs",
    "test": "npm run test:claymatching && npm run test:relay",
    "deploy:dry-run": "npm run build && wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@mysten/dapp-kit-core": "^1.6.5",
    "@mysten/kiosk": "^1.3.5",
    "@mysten/sui": "^2.20.3"
  },
  "devDependencies": {
    "vite": "^8.0.16",
    "wrangler": "^4.110.0"
  }
}
